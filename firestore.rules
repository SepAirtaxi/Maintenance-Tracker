rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Anonymous (viewer) accounts may read but never write.
    function isMember() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Any authenticated user (including viewers) may read.
    // Only members may write. The transaction log (not role gates) provides
    // accountability for member writes.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if isMember() && request.auth.uid == uid;
    }

    match /aircraft/{tailNumber} {
      allow read: if signedIn();
      allow write: if isMember();

      match /auditLog/{entryId} {
        allow read: if signedIn();
        allow create: if isMember();
        allow update, delete: if false;
      }
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if isMember();
    }

    match /defects/{defectId} {
      allow read: if signedIn();
      allow write: if isMember();
    }
  }
}
