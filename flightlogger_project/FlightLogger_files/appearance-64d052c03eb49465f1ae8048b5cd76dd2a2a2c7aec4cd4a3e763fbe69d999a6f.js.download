"undefined"!=typeof App&&App.cable.subscriptions.create("AppearanceChannel",{initialized:function(){this.update=this.update.bind(this),this.appear=this.appear.bind(this),this.install=this.install.bind(this),this.uninstall=this.uninstall.bind(this)},connected:function(){this.install(),this.update()},received:function(i){var t=i.appearance;Apps.lib.setupAppearance(t)},disconnected:function(){this.uninstall()},rejected:function(){this.uninstall()},update:function(i){void 0===i?"visible"!==document.visibilityState||this.appear():"visible"!==i.target.visibilityState||this.appear()},appear:function(){this.perform("appear",{appearing_on:document.URL})},install:function(){document.addEventListener("visibilitychange",this.update)},uninstall:function(){document.removeEventListener("visibilitychange",this.update)}});